{
    "name": "pseudocodium",
    "displayName": "Pseudocodium",
    "description": "Syntax highlighting and snippets for generic pseudocode. VSCodium-compatible, published on Open VSX.",
    "publisher": "realryanchoi",
    "icon": "logo.png",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "contributes": {
        "languages": [
            {
                "id": "pseudocode",
                "aliases": [
                    "Generic Pseudocode",
                    "pseudocode"
                ],
                "extensions": [
                    ".pseudo"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "pseudocode",
                "scopeName": "source.pseudo",
                "path": "./syntaxes/pseudocode.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "pseudocode",
                "path": "./snippets.json"
            }
        ]
    },
    "activationEvents": [
        "onLanguage:pseudocode"
    ],
    "main": "./out/extension.js",
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/realryanchoi/pseudocodium.git"
    },
    "bugs": {
        "url": "https://github.com/realryanchoi/pseudocodium/issues"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.74.0",
        "typescript": "^5.7.0"
    },
    "dependencies": {}
}
